{
  "name": "soroban-event-indexer",
  "version": "1.0.0",
  "description": "A production-grade event indexer for Soroban smart contracts",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "migrate": "prisma migrate dev",
    "seed": "ts-node scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@stellar/stellar-sdk": "^11.0.0",
    "express": "^4.18.2",
    "pino": "^8.14.1",
    "prisma": "^5.0.0",
    "ws": "^8.13.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.2",
    "@types/ws": "^8.5.5",
    "@vitest/coverage-v8": "^0.33.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "vitest": "^0.33.0"
  }
}
