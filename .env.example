# Soroban RPC
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/soroban_indexer

# Redis
REDIS_URL=redis://localhost:6379

# Indexer
CONTRACT_IDS=C...,C...
POLLING_INTERVAL_MS=5000
NETWORKS=[{"name":"testnet","rpcUrl":"https://soroban-testnet.stellar.org","passphrase":"Test SDF Network ; September 2015"}]

# API
PORT=3000
API_KEY_SECRET=your-secret-here
LOG_LEVEL=info
NODE_ENV=development