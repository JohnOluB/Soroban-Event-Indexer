{
    "compilerOptions": {
      "target": "ES2022",
      "module": "CommonJS",
      "rootDir": "./src",
      "outDir": "./dist",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "resolveJsonModule": true,
      "paths": {
        "@/*": ["./src/*"],
        "@config/*": ["./config/*"]
      }
    },
    "include": ["src/**/*", "config/**/*", "scripts/**/*"],
    "exclude": ["node_modules", "dist"]
  }